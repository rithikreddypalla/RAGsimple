# OpenAI (or compatible) API key — required
OPENAI_API_KEY=your_openai_api_key_here

# LLM model to use (default: gpt-4o-mini)
MODEL_NAME=gpt-4o-mini

# Sentence-transformer embedding model (default: all-MiniLM-L6-v2)
EMBED_MODEL=all-MiniLM-L6-v2

# Directory where ChromaDB persists the vector store
CHROMA_PATH=./chroma_db

# Directory containing source documents (PDF, TXT)
DATA_PATH=./data
